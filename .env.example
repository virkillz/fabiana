# Fabiana Environment Configuration
#
# You have 2 options to set credentials:
# 1. Copy this file to .env and fill in your values
# 2. Set environment variables directly (e.g., export TELEGRAM_BOT_TOKEN=xxx)
#
# Note: You don't have to use this .env file if you prefer setting environment variables another way.

# Telegram Bot (required for chat mode)
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_CHAT_ID=your_chat_id

# Get your bot token from @BotFather on Telegram
# Get your chat ID by messaging @userinfobot

# OpenRouter (for pi SDK)
OPENROUTER_API_KEY=your_openrouter_key

# Optional: Custom model override
# MODEL_PROVIDER=openrouter
# MODEL_ID=anthropic/claude-sonnet-4-5

BRAVE_API_KEY=your_brave_api_key

# Google Calendar (optional)
GOOGLE_CALENDAR_EMAIL=your@gmail.com
