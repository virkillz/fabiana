{
  "version": "0.1.0",
  "description": "Fabiana permission manifest - controls what the agent can read/write",
  "permissions": {
    "readonly": [
      ".fabiana/config/manifest.json",
      ".fabiana/config/plugins.json",
      ".fabiana/config/system.md",
      ".fabiana/config/system-chat.md",
      ".fabiana/config/system-consolidate.md",
      ".fabiana/config/system-external.md",
      ".fabiana/config/state.json",
      ".fabiana/config/config.json",
      "src/**",
      "package.json",
      "tsconfig.json"
    ],
    "writable": [
      ".fabiana/config/system-initiative.md",
      ".fabiana/data/memory/**",
      ".fabiana/data/agent-todo/**"
    ],
    "appendonly": [
      ".fabiana/data/logs/**"
    ]
  }
}