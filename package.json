{
  "name": "fabiana",
  "version": "0.2.0",
  "description": "Personal AI assistant that actually feels personal",
  "type": "module",
  "bin": {
    "fabiana": "bin/fabiana.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node scripts/build-plugins.js",
    "prepare": "npm run build",
    "dev": "tsx src/cli.ts start",
    "start": "tsx src/cli.ts start",
    "initiative": "tsx src/cli.ts initiative",
    "consolidate": "tsx src/cli.ts consolidate",
    "doctor": "tsx src/cli.ts doctor"
  },
  "files": [
    "bin/",
    "dist/"
  ],
  "keywords": [
    "ai",
    "agent",
    "assistant",
    "pi",
    "telegram"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@inquirer/prompts": "^7.10.1",
    "@mariozechner/pi-ai": "latest",
    "@mariozechner/pi-coding-agent": "latest",
    "@mozilla/readability": "^0.6.0",
    "@slack/bolt": "^4.6.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "esbuild": "^0.25.0",
    "linkedom": "^0.18.12",
    "minimatch": "^10.0.0",
    "node-cron": "^3.0.3",
    "telegraf": "^4.16.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
